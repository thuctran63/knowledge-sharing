# Database
DATABASE_URL="postgresql://user:password@localhost:5432/knowledge_sharing?pgbouncer=true&connection_limit=1"
# Neon (serverless): use pooled URL to cut cold-query latency, e.g.
# DATABASE_URL="postgresql://...@ep-xxx.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# NextAuths
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudflare R2
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="knowledge-sharing"
# R2_PUBLIC_URL="https://pub-your-hash.r2.dev"

# Cron (Vercel Cron / GitHub Actions → GET /api/cron/cleanup)
CRON_SECRET="your-cron-secret"
